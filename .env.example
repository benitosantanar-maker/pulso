# Café Comercial — variables de entorno
# Copia este archivo como .env.local para desarrollo local.
# Los valores reales van en Vercel → Project Settings → Environment Variables.

# ── Claude AI (Brief del día dinámico) ────────────────────────────────────────
# Genera el brief diario analizando ~60 artículos de RSS con Claude.
# Obtén tu key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Newsletter ────────────────────────────────────────────────────────────────
# Opción A: Resend (recomendado — gratis hasta 3.000 emails/mes)
# https://resend.com/api-keys
RESEND_API_KEY=

# Opción B: Mailchimp
# https://mailchimp.com/developer/marketing/guides/quick-start/
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# ── Revalidación ISR (opcional) ───────────────────────────────────────────────
# Token secreto para disparar revalidación on-demand vía webhook
# Genera uno con: openssl rand -hex 32
REVALIDATE_SECRET=
